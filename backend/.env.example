# 腾讯云 MySQL（见 docs/云数据库使用.docx）
DB_HOST=bj-cdb-mcxp1yss.sql.tencentcdb.com
DB_PORT=23196
DB_USER=zbl
DB_PASSWORD=zbl123456
DB_NAME=carmate

# JWT
JWT_SECRET=carmate-dev-secret-change-in-production
JWT_EXPIRE_HOURS=72

# 用户隐私数据加密（AES-256-GCM，全队开发环境共用；正式上线请更换）
DATA_ENCRYPTION_KEY=carmate-dev-privacy-key-32bytes!!

# 验证码有效期（秒）
CODE_TTL_SECONDS=300

# 邮箱验证码（全队开发共用发信专用 QQ 号，复制到 backend/.env 即可）
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=3940040862@qq.com
SMTP_PASSWORD=krerumkeoaiocegc
SMTP_FROM=3940040862@qq.com
# 若仅本地调试、不看真实邮件，可改为 EMAIL_PROVIDER=mock

# Mock 微信扫码登录
WECHAT_MOCK_ENABLED=true
WECHAT_SESSION_TTL_SECONDS=300
# 一般留空即可，后端会自动检测 WLAN IP；仅自动检测失败时再手动填写
# WECHAT_CONFIRM_BASE_URL=http://192.168.1.5:8000
API_PORT=8000

# 交警手势识别推理设备
# auto: 有 CUDA GPU 就使用 GPU，否则回退 CPU
# cuda: 强制使用 NVIDIA GPU；CUDA 不可用时后端启动失败并提示原因
# cpu: 强制使用 CPU，适合没有 NVIDIA 显卡或 CUDA 不稳定的电脑
CARMATE_DEVICE=auto

# 视频采样帧率。数值越高越准确但越慢；GPU 模式可以适当调高
CARMATE_VIDEO_SAMPLE_FPS=15
CARMATE_LSTM_WARMUP_FRAMES=15
CARMATE_SMOOTH_WINDOW=5
CARMATE_MIN_SEGMENT_SECONDS=0.6

# 标签时间补偿。LSTM 通常要观察一小段动作才稳定输出，
# 因此把显示标签整体向前移动一点，减少“动作快结束才出现标签”的体感延迟。
CARMATE_LABEL_TIME_OFFSET_SECONDS=0.8

# 浏览器预览视频自动转码。后端会用 FFmpeg 生成 H.264/yuv420p MP4 供 <video> 播放。
# 如系统 ffmpeg 不在 PATH，可安装 requirements.txt 中的 imageio-ffmpeg。
CARMATE_PREVIEW_MAX_WIDTH=1280
CARMATE_PREVIEW_CRF=23
CARMATE_PREVIEW_TRANSCODE_TIMEOUT_SECONDS=300
# CARMATE_FFMPEG_PATH=D:\tools\ffmpeg\bin\ffmpeg.exe
